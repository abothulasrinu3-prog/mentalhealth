PORT=5000
MONGO_URI=mongodb://localhost:27017/mindcare_ai
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
ML_SERVICE_URL=http://localhost:5001
NODE_ENV=development
CLIENT_URL=http://localhost:5173
ALLOWED_ORIGINS=
ALLOW_VERCEL_PREVIEW=false
VERCEL_PROJECT_NAME=

# Live nutrition providers - keep these on the backend only
# Edamam is used for direct food nutrition analysis.
EDAMAM_APP_ID=replace_with_edamam_app_id
EDAMAM_APP_KEY=replace_with_edamam_app_key

# FatSecret is used as a fallback direct food lookup provider.
FATSECRET_CLIENT_ID=replace_with_fatsecret_client_id
FATSECRET_CLIENT_SECRET=replace_with_fatsecret_client_secret

# Spoonacular is used for recipe search.
SPOONACULAR_API_KEY=replace_with_spoonacular_api_key

# Optional wearable integration readiness
GOOGLE_FIT_CLIENT_ID=replace_with_google_fit_client_id
GOOGLE_FIT_CLIENT_SECRET=replace_with_google_fit_client_secret
GOOGLE_FIT_REDIRECT_URI=http://localhost:5000/api/integrations/google-fit/callback
